# Copy to .env and adjust for local overrides.
# All values are optional — defaults are sensible.

# Host to bind. Only 127.0.0.1 is allowed (enforced in code).
ARGOS_HOST=127.0.0.1

# Port. 0 = pick a random free port (recommended).
ARGOS_PORT=0

# Auto-open browser on launch.
ARGOS_AUTO_OPEN_BROWSER=true

# Cache database path. Relative paths resolve to the app data dir.
ARGOS_CACHE_DB=cache.sqlite

# Log level: DEBUG | INFO | WARNING | ERROR
ARGOS_LOG_LEVEL=INFO

# Include hidden/system files by default on scan (user can toggle in UI).
ARGOS_INCLUDE_HIDDEN=false
